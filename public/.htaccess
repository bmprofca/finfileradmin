<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always unset Content-Security-Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://checkout.razorpay.com https://api.razorpay.com https://cdn.razorpay.com https://*.razorpay.com https://challenges.cloudflare.com https://maps.googleapis.com https://accounts.google.com/gsi/client https://sandbox-payments.open.money https://payments.open.money https://sdk.cashfree.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com/gsi/style; img-src 'self' data: blob: https: https://*.razorpay.com https://cdn.razorpay.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https: wss: https://server.onechatting.com https://*.w1chat.com https://checkout.razorpay.com https://api.razorpay.com https://cdn.razorpay.com https://*.razorpay.com https://challenges.cloudflare.com https://accounts.google.com/gsi/ https://*.cashfree.com https://sdk.cashfree.com; frame-src 'self' https://checkout.razorpay.com https://api.razorpay.com https://cdn.razorpay.com https://*.razorpay.com https://challenges.cloudflare.com https://accounts.google.com/gsi/ https://sandbox-payments.open.money https://payments.open.money https://*.cashfree.com https://sdk.cashfree.com https://www.facebook.com https://web.facebook.com https://*.facebook.com https://www.google.com https://maps.google.com https://*.google.com; child-src 'self' blob: https://checkout.razorpay.com https://api.razorpay.com https://cdn.razorpay.com https://*.razorpay.com https://*.cashfree.com https://www.facebook.com https://*.facebook.com https://www.google.com https://maps.google.com https://*.google.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://api.razorpay.com https://*.cashfree.com"
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
</IfModule>
